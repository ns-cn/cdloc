#!/bin/sh
# prepare-commit-msg hook: 更新版本文件的最后提交时间
# 用法: prepare-commit-msg <commit_message_file>

COMMIT_MSG_FILE="$1"

# 获取当前时间（ISO 8601 格式，带时区）
COMMIT_TIME=$(date -u "+%Y-%m-%dT%H:%M:%S+08:00")

# 更新版本文件
node -e "
const fs = require('fs');
const path = require('path');
const versionFile = path.join(process.cwd(), 'data/version.json');
try {
  const version = JSON.parse(fs.readFileSync(versionFile, 'utf8'));
  version.lastCommit = '$COMMIT_TIME';
  fs.writeFileSync(versionFile, JSON.stringify(version, null, 2) + '\n');
} catch (e) {
  // 忽略错误（文件不存在等情况）
}
"
