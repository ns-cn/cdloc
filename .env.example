# —— Vercel 环境变量模板 ——
# 复制到 Vercel Project Settings → Environment Variables

# 站点公开 URL（生产环境）
NEXT_PUBLIC_SITE_URL=https://longcheng.vercel.app

# 站点品牌名（覆盖 lib/site.ts 默认值，可选）
# NEXT_PUBLIC_SITE_NAME=隆诚装修记录

# Google Analytics 4 Measurement ID（可选）
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# 部署时关闭 Next.js 遥测（Vercel 默认关闭）
# NEXT_TELEMETRY_DISABLED=1
